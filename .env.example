# Server Configuration
PORT=8000
HOST=0.0.0.0

# Backup ports for multiple instances:
# Instance 1 (default): PORT=8000
# Instance 2: PORT=8001
# Instance 3: PORT=8002

# Database (Supabase)
SUPABASE_URL=https://zyougpdlujpaejjugecu.supabase.co
SUPABASE_KEY=your-supabase-service-role-key-here
DATABASE_URL=postgresql+asyncpg://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres

# Supabase Storage Buckets (these must be created in Supabase dashboard)
# Required buckets: ad-creatives, strategy-documents, screenshots, critique-files
# Make sure all buckets are set to public for file access
# AI Services
OPENAI_API_KEY=sk-...
GOOGLE_API_KEY=...
ANTHROPIC_API_KEY=sk-ant-...
TAVILY_API_KEY=...

# Meta Ad Library
META_ACCESS_TOKEN=...
META_APP_ID=...
META_APP_SECRET=...

# Celery / Redis
REDIS_URL=redis://localhost:6379/0

# App Configuration
RECOMMENDATION_MODEL=openai
# Options: "claude" or "openai"

# Analysis Configuration
TOP_N_ADS_FOR_RECOMMENDATIONS=10
AD_LOOKBACK_DAYS=90
MAX_ADS_PER_COMPETITOR=100
MIN_ENGAGEMENT_THRESHOLD=50

# Rate Limiting
META_RATE_LIMIT_PER_HOUR=200

REMOTION_AWS_REGION=us-east-1
REMOTION_FUNCTION_NAME=remotion-render-xxxxx
REMOTION_SITE_NAME=marketing-campaign-ai-us-east-1

# Optional explicit credentials (uses default chain if not set)
AWS_ACCESS_KEY_ID=...
AWS_SECRET_ACCESS_KEY=...

# Veo 2 B-Roll Generation
# Uses GOOGLE_API_KEY for authentication
VEO_ENABLED=true
VEO_MODEL=veo-2.0-generate-001
VEO_MAX_VARIANTS=4
VEO_MAX_DURATION_SECONDS=10
VEO_RATE_LIMIT_PER_MINUTE=10
VEO_PROMPT_MODEL=gemini-2.0-flash
