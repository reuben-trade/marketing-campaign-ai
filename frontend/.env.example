# Frontend Port Configuration
PORT=3000

# Backup ports for multiple instances:
# Instance 1 (default): PORT=3000
# Instance 2: PORT=3001
# Instance 3: PORT=3002

# Backend API URL
# Should match the backend PORT configuration
NEXT_PUBLIC_API_URL=http://localhost:8000

# For multiple instances, examples:
# Instance 1: NEXT_PUBLIC_API_URL=http://localhost:8000
# Instance 2: NEXT_PUBLIC_API_URL=http://localhost:8001
# Instance 3: NEXT_PUBLIC_API_URL=http://localhost:8002
